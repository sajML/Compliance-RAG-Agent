OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
EMBEDDING_MODEL=text-embedding-3-small
CHUNK_SIZE=512
CHUNK_OVERLAP=64
RETRIEVAL_TOP_K=10
FINAL_TOP_K=5
MAX_FILE_SIZE_MB=50

# ChromaDB connection (set CHROMA_HOST to use HTTP client instead of local PersistentClient)
# CHROMA_HOST=localhost
# CHROMA_PORT=8000
# CHROMA_SSL=false
# CHROMA_TOKEN=

# API key authentication (leave empty to disable)
# API_KEY=
